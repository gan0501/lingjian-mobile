<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="上传Logo"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <FrameLayout
        android:id="@+id/logo_upload_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/logo_upload_bg"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:id="@+id/iv_logo_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/upload_hint_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_add_photo"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="点击上传Logo"
                android:textColor="#999999"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_logo_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:text="支持 JPG、PNG 格式，建议尺寸 200x200"
        android:textColor="#999999"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp">

        <Button
            android:id="@+id/btn_logo_cancel"
            android:layout_width="120dp"
            android:layout_height="38dp"
            android:text="取消"
            android:textSize="14sp"
            android:background="@drawable/btn_cancel_bg"
            android:textColor="#666666" />

        <Button
            android:id="@+id/btn_logo_confirm"
            android:layout_width="120dp"
            android:layout_height="38dp"
            android:layout_marginStart="20dp"
            android:text="确认"
            android:textSize="14sp"
            android:background="@drawable/btn_confirm_bg"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
